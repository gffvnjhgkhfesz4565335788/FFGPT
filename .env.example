# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=

# Application URL (Used for MCP OAuth callback matching, defaults to http://localhost:3000)
# Remember to update this to your Render URL (e.g. https://my-app.onrender.com)
APP_URL=http://localhost:3000

# Require OAuth for MCP Access (true/false)
REQUIRE_OAUTH=true

# Auth0 / Independent OAuth 2.1 Identity Provider Issuer URL
# Set this to your Auth0 base domain (e.g. https://your-tenant.us.auth0.com)
OAUTH_AUTHORIZER_URL=
